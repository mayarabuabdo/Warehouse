@using Warehouse.Models
@model List<Country>

@{
    ViewData["Title"] = "Countries";
    Layout = "~/Views/Shared/NavBar.cshtml";
}

<style>
    :root {
        --brand: #14b8a6; /* Teal */
        --accent: #f59e0b; /* Gold */
        --ink: #1f2937; /* Dark text */
        --muted: #6b7280;
        --bg: #f6f3ee; /* Page background */
        --card: #ffffff;
        --shadow: rgba(0,0,0,0.15);
        --light-gray: rgb(240, 240, 240);
    }

    body {
        background: var(--bg);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        margin: 0;
        padding: 0;
    }

    .table-wrapper {
        display: flex;
        justify-content: center;
        padding: 2rem;
    }

    .table-container {
        flex: 1;
        max-width: 1100px;
        background: var(--card);
        border-radius: 15px;
        box-shadow: 0 20px 40px var(--shadow);
        padding: 1.5rem;
        border: 2px solid var(--brand);
        overflow-x: auto; /* enables horizontal scroll for small screens */
    }

    .country-icon {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--brand), var(--accent));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        color: #fff;
        margin: 0 auto 1rem auto;
        box-shadow: 0 5px 15px rgba(0,0,0,0.15);
    }

    h2 {
        text-align: center;
        font-size: clamp(1.4rem, 2vw, 2rem);
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 1.5rem;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        min-width: 600px;
    }

    thead th {
        background: var(--card); /* match Employee Request style */
        color: var(--ink);
        text-align: center;
        font-weight: 600;
        padding: 1rem;
        font-size: clamp(0.85rem, 1.5vw, 1rem);
        border-bottom: 3px solid var(--brand); /* teal underline */
    }

        thead th:first-child {
            border-top-left-radius: 8px;
        }

        thead th:last-child {
            border-top-right-radius: 8px;
        }

    tbody td {
        padding: 0.9rem 1rem;
        text-align: center;
        border-bottom: 1px solid var(--light-gray);
        font-weight: 500;
        color: var(--ink);
        font-size: clamp(0.8rem, 1.3vw, 0.95rem);
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    tbody tr:nth-child(even) {
        background: rgba(20, 184, 166, 0.05); /* zebra stripe */
    }

    tbody tr:hover {
        background: rgba(20, 184, 166, 0.1);
    }

    .btn-action {
        padding: 0.4rem 0.8rem;
        font-size: clamp(0.7rem, 1.2vw, 0.85rem);
        border-radius: 8px;
        font-weight: 600;
        margin: 0 3px;
        transition: all 0.2s ease;
        border: none;
        text-decoration: none;
        display: inline-block;
        white-space: nowrap;
    }

    .btn-edit {
        background: var(--accent);
        color: #fff;
    }

        .btn-edit:hover {
            background: #fbbf24;
            transform: translateY(-2px);
        }

    .btn-delete {
        background: #ef4444;
        color: #fff;
    }

        .btn-delete:hover {
            background: #f87171;
            transform: translateY(-2px);
        }

    .btn-add {
        display: inline-block;
        margin-top: 1.2rem;
        background: var(--brand);
        color: #fff;
        padding: 0.7rem 1.4rem;
        border-radius: 10px;
        font-weight: 600;
        border: none;
        transition: 0.25s;
        text-decoration: none;
        font-size: clamp(0.85rem, 1.5vw, 1rem);
    }

        .btn-add:hover {
            background: var(--accent);
            transform: translateY(-2px);
        }

    .text-end {
        text-align: right;
    }
</style>

<div class="table-wrapper">
    <div class="table-container">
        <div class="country-icon">
            <i class="fa-solid fa-earth-americas"></i>
        </div>
        <h2>All Countries</h2>

        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Country Code</th>
                    <th>Phone Code</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (Country country in Model)
                {
                    <tr>
                        <td>@country.Name</td>
                        <td>@country.CountryCode</td>
                        <td>@country.PhoneCode</td>
                        <td>
                            @if ((bool)ViewData["IsActivated"] == true)
                            {
                                <div style="display:flex; justify-content:center; flex-wrap:wrap;">
                                    <form method="post">
                                        <input type="hidden" name="Name" value="@country.Name" />
                                        <input type="hidden" name="CountryCode" value="@country.CountryCode" />
                                        <input type="hidden" name="PhoneCode" value="@country.PhoneCode" />
                                        <input type="hidden" name="Id" value="@country.Id" />
                                        <button class="btn-action btn-edit" type="submit" asp-controller="Country" asp-action="EditCountryPage">
                                            <i class="fa-solid fa-pen"></i> Edit
                                        </button>
                                    </form>

                                    <a class="btn-action btn-delete" asp-controller="Country" asp-action="DeactivateCountry" asp-route-CountryId="@country.Id">
                                        Deactivate
                                    </a>
                                </div>
                            }
                            else
                            {
                                <a class="btn-action btn-add" asp-controller="Country" asp-action="ActivateCountry" asp-route-CountryId="@country.Id">
                                    Activate
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if ((bool)ViewData["IsActivated"] == true)
        {
            <div class="text-end">
                <a class="btn-add" asp-controller="Country" asp-action="AddCountrypages">
                    <i class="fa-solid fa-plus me-2"></i> Add Country
                </a>
            </div>
        }
    </div>
</div>
