@using Warehouse.Models
@model GroupModel
@{
    ViewData["Title"] = "AddGroup";
    Layout = "~/Views/Shared/NavBar.cshtml";
}
<style>
    :root {
        --brand: #14b8a6; /* Teal */
        --accent: #f59e0b; /* Gold */
        --ink: #1f2937; /* Dark text */
        --muted: #6b7280;
        --bg: #f6f3ee; /* Page background */
        --card: #ffffff;
        --shadow: rgba(0,0,0,0.15);
    }

    body {
        background: var(--bg);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        margin: 0;
        padding: 0;
    }

    nav.navbar {
        margin-top: 0;
    }

    .form-wrapper {
        display: flex;
        justify-content: center;
        padding: 3rem 2rem 2rem 2rem; /* top padding moves card below navbar */
    }

    .form-card {
        background: var(--card);
        border-radius: 15px;
        box-shadow: 0 25px 60px var(--shadow);
        padding: 3rem 3.5rem;
        width: 100%;
        max-width: 600px;
        border: 2px solid var(--brand);
    }

    /* Top icon for role */
    .role-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--accent), var(--brand));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: #fff;
        margin: 0 auto 1rem auto;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .form-card h2 {
        text-align: center;
        font-size: 2rem;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 1.5rem;
    }

    .form-label {
        color: var(--ink);
        font-weight: 600;
    }

    .form-control {
        border-color: #e5e7eb;
        border-radius: 12px;
        padding: 0.8rem 1.2rem;
        font-size: 1rem;
        transition: all 0.2s ease-in-out;
    }

        .form-control:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 .25rem rgba(20,184,166,.15);
        }

    .btn-add {
        width: 100%;
        padding: 0.8rem;
        font-weight: 600;
        font-size: 1.1rem;
        background: linear-gradient(90deg, var(--accent), var(--brand));
        border: none;
        border-radius: 12px;
        color: var(--ink);
        box-shadow: 0 10px 25px rgba(20,184,166,.2);
        transition: all 0.25s ease-in-out;
        margin-top: 2rem;
    }

        .btn-add:hover {
            filter: brightness(1.05);
            transform: translateY(-2px);
        }
</style>
<div class="form-wrapper d-flex mt-5">
    <div class="form-card">
        <!-- Role icon -->
        <div class="role-icon">
            <i class="fa-solid fa-user-shield"></i>
        </div>

        <h2>Add New Group</h2>

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Group Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter Group name" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-add" asp-action="AddGroup" asp-controller="Group">
                <i class="fa-solid fa-plus me-2"></i> Add Group
            </button>
        </form>
    </div>
</div>

