@using Warehouse.Models
@model WarehouseItemsVm
@{
    ViewData["Title"] = "AddWarehoueItems";
    Layout = "~/Views/Shared/NavBar.cshtml";
}

<style>
    :root {
        --brand: #14b8a6; /* Teal */
        --accent: #f59e0b; /* Gold */
        --ink: #1f2937; /* Dark text */
        --muted: #6b7280;
        --bg: #f6f3ee; /* Page background */
        --card: #ffffff;
        --shadow: rgba(0,0,0,0.15);
    }

    body {
        background: var(--bg);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        margin: 0;
        padding: 0;
    }

    .form-wrapper {
        display: flex;
        justify-content: center;
        padding: 3rem 2rem;
    }

    .form-card {
        background: var(--card);
        border-radius: 15px;
        box-shadow: 0 25px 60px var(--shadow);
        padding: 2rem 3rem;
        width: 100%;
        max-width: 650px;
        border: 2px solid var(--brand);
    }

    .warehouse-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--accent), var(--brand));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: #fff;
        margin: 0 auto 1rem auto;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .form-card h2 {
        text-align: center;
        font-size: 2rem;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 1.5rem;
    }

    .form-label {
        color: var(--ink);
        font-weight: 600;
    }

    .form-control, .form-select {
        border-color: #e5e7eb;
        border-radius: 12px;
        padding: 0.8rem 1.2rem;
        font-size: 1rem;
        transition: all 0.2s ease-in-out;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 .25rem rgba(20,184,166,.15);
        }

    .btn-add {
        padding: 0.8rem;
        font-weight: 600;
        font-size: 1.1rem;
        background: linear-gradient(90deg, var(--accent), var(--brand));
        border: none;
        border-radius: 12px;
        color: var(--ink);
        box-shadow: 0 10px 25px rgba(20,184,166,.2);
        transition: all 0.25s ease-in-out;
    }

        .btn-add:hover {
            filter: brightness(1.05);
            transform: translateY(-2px);
        }

    .btn-row {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin-top: 2rem;
    }

        .btn-row .btn-add {
            flex: 1;
            text-align: center;
        }
</style>

<div class="form-wrapper">
    <div class="form-card">
        <!-- Icon -->
        <div class="warehouse-icon">
            <i class="fa-solid fa-box"></i>
        </div>

        <h2>@((bool)ViewData["isNew"] ? "Add Warehouse Item" : "Edit Warehouse Item")</h2>

        <form method="post">
            <div class="mb-3">
                <label for="Name" class="form-label">Item Name</label>
                <input type="text" class="form-control" id="Name" name="Name"
                       value="@Model.warehouseItems.Name" placeholder="Enter item name" required>
            </div>

            <div class="mb-3">
                <label for="KUCode" class="form-label">KU Code</label>
                <input type="text" class="form-control" id="KUCode" name="KUCode"
                       value="@Model.warehouseItems.KUCode" placeholder="Enter KU Code" >
            </div>

            <div class="mb-3">
                <label for="Qty" class="form-label">Quantity</label>
                <input type="number" class="form-control" id="Qty" name="Qty"
                       value="@Model.warehouseItems.Qty" placeholder="Enter quantity" min="0" required>
            </div>

            <div class="mb-3">
                <label for="CostPrice" class="form-label">Cost Price</label>
                <input type="number" step="any" class="form-control" id="CostPrice"
                       name="CostPrice" value="@Model.warehouseItems.CostPrice" placeholder="Enter cost price" min="0" required>
            </div>

            <div class="mb-3">
                <label for="MSRPPrice" class="form-label">MSRP Price</label>
                <input type="number" step="any" class="form-control" id="MSRPPrice"
                       name="MSRPPrice" value="@Model.warehouseItems.MSRPPrice" placeholder="Enter MSRP price" min="0" required>
            </div>

            <div class="mb-3">
                <label for="WarehouseId" class="form-label">Warehouse</label>
                <select class="form-select" id="WarehouseId" name="WarehouseId" required>
                    <option value="">Select Warehouse</option>
                    @foreach (WarehouseModel warehouse in Model.warehouseModel)
                    {
                        <option value="@warehouse.Id"
                                selected="@(Model.warehouseItems.WarehouseId == warehouse.Id)">
                            @warehouse.Name
                        </option>
                    }
                </select>
            </div>

            <input type="hidden" name="Id" value="@Model.warehouseItems.Id" />

            @if ((bool)ViewData["isNew"])
            {
                <div class="btn-row">
                    <button type="submit" class="btn-add"
                            asp-action="AddWarehoueItems" asp-controller="WarehouseItems">
                        <i class="fa-solid fa-plus me-2"></i> Add Item
                    </button>

                    <a class="btn-add text-decoration-none d-flex align-items-center justify-content-center"
                       asp-controller="WarehouseItems" asp-action="AddWarehoueItemsPage">
                        <i class="fa-solid fa-xmark me-2"></i> Cancel
                    </a>
                </div>
            }
            else
            {
                <div class="btn-row">
                    <button type="submit" class="btn-add"
                            asp-action="EidtWarehouseItem" asp-controller="WarehouseItems">
                        <i class="fa-solid fa-pen me-2"></i> Update Item
                    </button>
                </div>
            }
        </form>
    </div>
</div>
