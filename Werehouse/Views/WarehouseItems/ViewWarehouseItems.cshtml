@using Warehouse.Models
@model List<WarehouseItems>
@{
    ViewData["Title"] = "View Warehouse Items";
    Layout = "~/Views/Shared/NavBar.cshtml";
}

<style>
    :root {
        --brand: #14b8a6; /* Teal */
        --accent: #f59e0b; /* Gold */
        --ink: #1f2937; /* Dark text */
        --muted: #6b7280;
        --bg: #f6f3ee; /* Page background */
        --card: #ffffff;
        --shadow: rgba(0,0,0,0.1);
        --light: #ffffff;
    }

    body {
        background: var(--bg);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .table-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 30px;
        gap: 1rem;
    }

    .table-container {
        width: 95%;
        max-width: 1200px;
        background: var(--card);
        border-radius: 12px;
        box-shadow: 0 15px 40px var(--shadow);
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    h2 {
        text-align: center;
        font-size: 2rem;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 1rem;
    }

    .avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--accent), var(--brand));
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: bold;
        margin: 0 auto 1rem auto;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 1rem;
        color: var(--ink);
        border: 2px solid var(--brand);
        border-radius: 8px;
        overflow: hidden;
    }

    thead th {
        padding: 0.8rem 1rem;
        border-bottom: 2px solid var(--accent);
        text-align: center;
        font-weight: 600;
        background: var(--card);
    }

    tbody td {
        padding: 0.75rem 1rem;
        text-align: center;
        border-bottom: 1px solid #e0e0e0;
        border-right: 1px solid #e0e0e0;
        font-weight: 500;
        transition: all 0.15s ease-in-out;
    }

        tbody td:last-child {
            border-right: none;
        }

    tbody tr:last-child td {
        border-bottom: none;
    }

    tbody tr:hover {
        background: rgba(20, 184, 166, 0.05);
    }

    .btn-action {
        padding: 0.35rem 0.9rem;
        font-size: 0.85rem;
        border-radius: 8px;
        font-weight: 600;
        margin: 0 2px;
        transition: all 0.2s ease;
        display: inline-block;
        text-decoration: none;
        color: #fff;
        border: none;
    }

    .btn-edit {
        background: var(--accent);
    }

        .btn-edit:hover {
            background: #fbbf24;
            transform: translateY(-1px);
        }

    .btn-delete {
        background: #ef4444;
       
    }

        .btn-delete:hover {
            background: #f87171;
            transform: translateY(-1px);
        }

    /* Add button inside card aligned right */
    .add-btn-wrapper {
        display: flex;
        justify-content: flex-end;
        margin-top: 1rem;
    }

    .btn-add {
        background-color: var(--brand);
        color: var(--light);
        padding: 0.5rem 1.2rem;
        font-size: 0.95rem;
        border-radius: 10px;
        font-weight: 600;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s ease;
        text-decoration: none;
    }

        .btn-add:hover {
            background-color: #0d9488; /* Darker teal on hover */
            transform: translateY(-1px);
        }

    .btn-disabled {
        color: #fff;
        padding: 0.5rem 1.2rem;
        border-radius: 8px;
        font-weight: 600;
        margin: 0 2px;
        transition: all 0.2s ease;
        display: inline-block;
        text-decoration: none;
        background-color: #D3D3D3;
    }
</style>

<div class="table-wrapper">
    <div class="table-container">
        <div class="avatar">
            <i class="fa-solid fa-box"></i>
        </div>

        <h2>All Warehouse Items</h2>

        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>KUCode</th>
                    <th>Qty</th>
                    <th>Cost Price</th>
                    <th>MSRP Price</th>
                    <th>Warehouse</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (WarehouseItems warehouseItem in Model)
                {
                    <tr>
                        <td>@warehouseItem.Name</td>
                        <td>@warehouseItem.KUCode</td>
                        <td>@warehouseItem.Qty</td>
                        <td>@warehouseItem.CostPrice</td>
                        <td>@warehouseItem.MSRPPrice</td>
                        <td>@warehouseItem.WarehouseName</td>
                        <td>
                            @if ((bool)ViewData["IsActive"] == true)
                            {
                                <div class="d-flex justify-content-center gap-1">
                                    <form method="post">
                                        <input type="hidden" name="warehouseId" value="@warehouseItem.Id" />
                                        <button class="btn-action btn-delete" type="submit" asp-controller="WarehouseItems" asp-action="DeactivateWarehouseItem">
                                            Deactive
                                        </button>
                                    </form>
                                    <form method="post" asp-controller="WarehouseItems" asp-action="EditWarehousePage">
                                        <input type="hidden" name="Id" value="@warehouseItem.Id" />
                                        <input type="hidden" name="Name" value="@warehouseItem.Name" />
                                        <input type="hidden" name="Qty" value="@warehouseItem.Qty" />
                                        <input type="hidden" name="CostPrice" value="@warehouseItem.CostPrice" />
                                        <input type="hidden" name="MSRPPrice" value="@warehouseItem.MSRPPrice" />
                                        <input type="hidden" name="WarehouseName" value="@warehouseItem.WarehouseName" />
                                        <input type="hidden" name="KUCode" value="@warehouseItem.KUCode" />
                                        <input type="hidden" name="WarehouseId" value="@warehouseItem.WarehouseId" />
                                        <button class="btn-action btn-edit" type="submit">Edit</button>
                                    </form>
                                </div>
                            }
                            else
                            {
                                if (warehouseItem.IsWarehouseActive == true)
                                {
                                    <form method="post">
                                        <input type="hidden" name="warehouseId" value="@warehouseItem.Id" />
                                        <button class="btn-action btn-add" type="submit" asp-controller="WarehouseItems" asp-action="ActivateWarehouseItem">
                                            Activate
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn-action btn-disabled" type="submit">
                                        Activate
                                    </button>
                                }

                            }

                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if ((bool)ViewData["IsActive"] == true)
        {
            <div class="add-btn-wrapper">
                <a class="btn-add" asp-controller="WarehouseItems" asp-action="AddWarehoueItemsPage">
                    <i class="fa-solid fa-plus"></i> Add Item
                </a>
            </div>
        }

    </div>
</div>
