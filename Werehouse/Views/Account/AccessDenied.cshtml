@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - WareFlow</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<div style="height: 100vh; display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, #fee2e2 0%, #fef3c7 100%);">
    <div class="text-center">
        <!-- Warning icon -->
        <i class="bi bi-exclamation-triangle-fill" style="font-size: 100px; color: #ef4444;"></i>

        <!-- Title -->
        <h1 style="font-size: 50px; font-weight: 700; color: #b91c1c; margin-top: 20px;">
            Access Denied
        </h1>

        <!-- Subtitle -->
        <p style="font-size: 22px; color: #374151; margin-top: 15px;">
            You do not have permission to access this page. <br />
            Please contact your administrator if you believe this is an error.
        </p>

        <!-- Decorative icons (warehouse theme) -->
        <div class="mt-5 d-flex justify-content-center gap-4" style="font-size: 40px; color: #6b7280;">
            <i class="bi bi-warehouse-fill"></i>
            <i class="bi bi-box-seam-fill"></i>
            <i class="bi bi-truck"></i>
        </div>
    </div>
</div>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</body>
</html>